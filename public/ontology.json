{
  "name": "MENA Oil & Gas ESG Ontology",
  "version": "1.0",
  "date": "2026-06-21",
  "author": "Mohammed Farhan (ENGG940 Dissertation, University of Wollongong)",
  "description": "Domain-specific, machine-readable ESG ontology for automated analysis of MENA oil & gas supplier sustainability reports. Three tiers: Pillar -> Topic -> terms/synonyms/variants. Includes GRI 11 + SASB tagging, quantitative flags with unit hints, region-specific localization vocabulary, and a greenwashing/confidence-scoring lexicon.",
  "framework_basis": [
    "GRI 11: Oil and Gas Sector 2021",
    "GRI Topic Standards (200/300/400 series)",
    "SASB EM-EP (Exploration & Production) and EM-SV (Services)",
    "TCFD"
  ],
  "tiers": {
    "tier_1": "ESG pillar (Environmental / Social / Governance)",
    "tier_2": "Topic (e.g. GHG Emissions)",
    "tier_3": "keywords / synonyms / industry variants that map to the topic"
  },
  "pipeline_usage": {
    "component_A_classification": "tier-1/tier-2 provide the label schema; tier-3 terms seed weak-supervision labels for fine-tuning DistilBERT",
    "component_B_regex": "topics with quantitative=true + their units drive the regex extraction patterns",
    "component_C_ner": "keywords + region_specific feed the spaCy EntityRuler (certifications, targets, ICV references)",
    "component_D_greenwashing": "greenwashing_lexicon + claim-vs-evidence comparison produce the per-report greenwashing/confidence score"
  },
