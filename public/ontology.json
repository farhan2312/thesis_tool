      "quantitative_substantiation": [
        "number followed by a unit (tCO2e, %, GJ, m3, rate)",
        "baseline year stated",
        "year-on-year change",
        "absolute figure with year"
      ],
      "assurance_transparency": [
        "third-party assured",
        "independently verified",
        "external assurance",
        "limited assurance",
        "reasonable assurance",
        "assurance statement",
        "in accordance with GRI",
