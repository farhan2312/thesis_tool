  "greenwashing_lexicon": {
    "purpose": "Detect the gap between narrative claims and substantiated data; produce a per-report greenwashing score (0-100, higher=worse) and an inverse confidence weight used in benchmarking. Framed as a transparent disclosure-quality risk indicator, NOT a definitive verdict.",
    "aspirational_vague_terms": [
