        "ISO 14001",
        "ISO 45001"
      ]
    },
    "scoring_model": {
      "output_range": "0-100 (higher = more greenwashing)",
      "confidence_weight": "confidence = 100 - greenwashing_score",
      "components": [
        {
          "name": "claim_substantiation_gap",
          "weight": 0.45,
          "definition": "share of ESG topics the report makes commitments/targets on but provides NO quantitative metric for"
        },
        {
          "name": "vague_language_density",
          "weight": 0.25,
          "definition": "aspirational + hedging term count normalised per 1,000 words"
        },
        {
          "name": "specificity_deficit",
          "weight": 0.2,
          "definition": "ratio of qualitative claims to quantitative data points (many words, few numbers)"
        },
        {
          "name": "assurance_deficit",
          "weight": 0.1,
          "definition": "absence of third-party assurance / framework-alignment signals"
        }
      ],
      "risk_bands": {
        "low": "0-30",
        "moderate": "31-60",
        "high": "61-100"
      },
      "weights_tunable": true
    }
  }
}